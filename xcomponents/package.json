{
  "name": "@xscriptor/xcomponents",
  "version": "0.2.2",
  "private": false,
  "description": "Reusable React/Next.js UI components by Xscriptor.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.mjs",
      "require": "./dist/components/index.js"
    },
    "./forms": {
      "types": "./dist/components/forms/index.d.ts",
      "import": "./dist/components/forms/index.mjs",
      "require": "./dist/components/forms/index.js"
    },
    "./navigation": {
      "types": "./dist/components/navigation/index.d.ts",
      "import": "./dist/components/navigation/index.mjs",
      "require": "./dist/components/navigation/index.js"
    },
    "./layout": {
      "types": "./dist/components/layout/index.d.ts",
      "import": "./dist/components/layout/index.mjs",
      "require": "./dist/components/layout/index.js"
    },
    "./content": {
      "types": "./dist/components/content/index.d.ts",
      "import": "./dist/components/content/index.mjs",
      "require": "./dist/components/content/index.js"
    },
    "./gallery": {
      "types": "./dist/components/gallery/index.d.ts",
      "import": "./dist/components/gallery/index.mjs",
      "require": "./dist/components/gallery/index.js"
    },
    "./social": {
      "types": "./dist/components/social/index.d.ts",
      "import": "./dist/components/social/index.mjs",
      "require": "./dist/components/social/index.js"
    }
  },
  "peerDependencies": {
    "framer-motion": ">=11",
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "esbuild": "^0.25.9",
    "framer-motion": "^11.15.0",
    "next": "^15.1.3",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "scripts": {
    "build": "npm run clean && node ./scripts/build.mjs && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepare:build": "npm run build",
    "prepublishOnly": "npm run prepare:build"
  }
}
